# Static Bot token (simple setup)
WEBEX_ACCESS_TOKEN=your_bot_access_token_here

# OAuth Integration (alternative to Bot token)
WEBEX_CLIENT_ID=
WEBEX_CLIENT_SECRET=
WEBEX_REDIRECT_URI=http://127.0.0.1:4321/oauth/callback
WEBEX_TOKEN_PATH=~/.config/webex-mcp/tokens.json
WEBEX_SCOPES=spark:rooms_read spark:rooms_write spark:memberships_write spark:messages_read spark:messages_write spark:people_read
